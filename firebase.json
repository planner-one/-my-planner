{
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "my-planner-487bd",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/reader/page",
        "function": { "functionId": "readerPage", "region": "asia-northeast3" }
      },
      {
        "source": "/reader/image",
        "function": { "functionId": "readerImage", "region": "asia-northeast3" }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
